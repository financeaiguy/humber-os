# Humber Operations Environment Configuration

# Application Environment
ENVIRONMENT=development
API_VERSION=1.0.0
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=your_database_url_here
DB_POOL_SIZE=10
DB_TIMEOUT=30000

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# D1 Database IDs
DB_MASTER_ID=your_master_database_id
DB_ENGINEER_001_ID=your_tenant_001_database_id
DB_ENGINEER_002_ID=your_tenant_002_database_id
DB_ENGINEER_003_ID=your_tenant_003_database_id
DB_ENGINEER_004_ID=your_tenant_004_database_id
DB_ENGINEER_005_ID=your_tenant_005_database_id
DB_ENGINEER_006_ID=your_tenant_006_database_id
DB_ENGINEER_007_ID=your_tenant_007_database_id
DB_ENGINEER_008_ID=your_tenant_008_database_id
DB_ENGINEER_009_ID=your_tenant_009_database_id
DB_ENGINEER_010_ID=your_tenant_010_database_id

# KV Namespace IDs
KV_CACHE_ID=your_kv_cache_namespace_id
KV_TENANT_CACHE_ID=your_tenant_cache_namespace_id
KV_SESSIONS_ID=your_sessions_namespace_id

# Queue Names
OPERATIONS_QUEUE_NAME=operations-queue
RECONCILIATION_QUEUE_NAME=reconciliation-queue
TENANT_QUEUE_NAME=tenant-audit-logs
VETTING_QUEUE_NAME=background-checks
VISA_QUEUE_NAME=visa-processing

# R2 Bucket Names
DOCUMENTS_BUCKET_NAME=humber-documents
BACKUPS_BUCKET_NAME=humber-backups

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here
SESSION_SECRET=your_session_secret_here

# API Rate Limiting
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=900000

# Email Configuration (Optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@humber-operations.com

# Webhook Configuration (Optional)
WEBHOOK_SECRET=your_webhook_secret
WEBHOOK_TIMEOUT=30000

# Monitoring and Analytics
ANALYTICS_API_KEY=your_analytics_api_key
ERROR_TRACKING_DSN=your_error_tracking_dsn
PERFORMANCE_MONITORING=true

# Feature Flags
ENABLE_BULL_PEN=true
ENABLE_TIMESHEET_RECONCILIATION=true
ENABLE_MULTI_TENANT=true
ENABLE_ADVANCED_ANALYTICS=false
ENABLE_API_RATE_LIMITING=true

# Business Configuration
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=America/New_York
DEFAULT_HOURLY_RATE=75.00
OVERTIME_MULTIPLIER=1.5

# Compliance and Audit
AUDIT_LOG_RETENTION_DAYS=2555
DATA_RETENTION_DAYS=365
GDPR_COMPLIANCE=true
CCPA_COMPLIANCE=true

# Development Only (Remove in production)
DEV_SEED_DATA=true
DEV_MOCK_EXTERNAL_APIS=false
DEV_BYPASS_AUTH=false
