    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.5",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "3",
    "typescript": "^5.7.2",
    "wrangler": "^4.59.1"
  }
