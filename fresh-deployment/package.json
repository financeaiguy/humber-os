{
  "name": "@humber/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "npx @cloudflare/next-on-pages",
    "deploy": "npm run build:cf && wrangler pages deploy .vercel/output/static --project-name=humber-complete --env production",
    "preview": "npm run build:cf && wrangler pages dev .vercel/output/static --binding KV_CACHE=KV_CACHE --binding AI=AI",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "clean": "rm -rf .next out .vercel"
  },
  "dependencies": {
    "@auth/core": "^0.40.0",
    "@auth/drizzle-adapter": "^1.10.0",
    "@humber/types": "workspace:*",
    "@humber/utils": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@sendgrid/mail": "^8.1.5",
    "@tanstack/react-query": "^5.65.1",
    "@types/jspdf": "^2.0.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ethers": "^6.15.0",
    "framer-motion": "^12.23.12",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.544.0",
    "next": "15.5.10",
    "next-auth": "5.0.0-beta.30",
    "nprogress": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.2.0",
    "tailwind-merge": "^3.3.1",
    "tesseract.js": "^6.0.1",
    "twilio": "^5.4.0",
    "zod": "^3.24.1"
  },
