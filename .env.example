# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_ID=your_account_id

# Cloudflare Workers AI (100% Open-Source Models)
# Models: Llama 4 Scout, 120B parameter OSS models
# No GPT or closed-source models used
WORKERS_AI_ENABLED=true
WORKERS_AI_MODEL_CHAT=@cf/meta/llama-3-8b-instruct
WORKERS_AI_MODEL_ANALYSIS=@cf/meta/llama-3-70b-instruct
WORKERS_AI_MODEL_CODE=@cf/meta/codellama-34b-instruct
WORKERS_AI_MODEL_EMBEDDINGS=@cf/baai/bge-base-en-v1.5

# Database Configuration
DATABASE_URL=your_d1_database_url
RECRUITING_ENCRYPTION_KEY=your_encryption_key

# Authentication
JWT_SECRET=your_jwt_secret
SESSION_SECRET=your_session_secret

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@humber-ops.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# R2 Storage
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=humber-documents

# Vectorize Configuration
VECTORIZE_INDEX_NAME=humber-knowledge-base

# KV Namespaces
KV_SESSIONS_NAMESPACE=sessions
KV_CACHE_NAMESPACE=cache

# Durable Objects
DO_NAMESPACE_REALTIME=realtime-state
DO_NAMESPACE_PRESENCE=user-presence

# Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_APP_URL=http://localhost:3000