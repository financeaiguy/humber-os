{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "outDir": "./dist-worker",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "src/worker-entry.tsx",
    "src/simplified-components.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist"
  ]
}
