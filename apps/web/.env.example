# Authentication
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL=your-database-url-here

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_APP_ENV=development

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15555551234
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid Email Configuration
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=notifications@humber.com
SENDGRID_FROM_NAME=Humber OS
SENDGRID_TEMPLATE_CLOCK_IN=d-xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_CLOCK_OUT=d-xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_ANOMALY=d-xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_DAILY=d-xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_WEEKLY=d-xxxxxxxxxxxxxxxxxxxxxxxx

# Push Notifications (Firebase/APNS)
FCM_SERVER_KEY=AAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APNS_KEY_ID=xxxxxxxxxx
APNS_TEAM_ID=xxxxxxxxxx
APNS_BUNDLE_ID=com.humber.timetracking

# Geolocation & Trust Verification
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEOFENCE_RADIUS_METERS=500
TRUST_SCORE_THRESHOLD=75
BIOMETRIC_REQUIRED=true
LOCATION_ACCURACY_THRESHOLD=50

# Monitoring (Optional)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx
VERCEL_ANALYTICS_ID=xxxxxxxxxx

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_TRUST_VERIFICATION=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true